		<enumeration name="MwKEY">
			<integer name="MwKEY_BACKSPACE">0x80000001</integer>
			<integer name="MwKEY_LEFT" />
			<integer name="MwKEY_RIGHT" />
			<integer name="MwKEY_UP" />
			<integer name="MwKEY_DOWN" />
