		        <integer name="MwVULKANFIELD_GRAPHICSQUEUE" />
		        <integer name="MwVULKANFIELD_PRESENTQUEUE" />
		</enumeration>
	</enumerations>
	<!-- You can assume all constants are unsigned -->
	<constants>
